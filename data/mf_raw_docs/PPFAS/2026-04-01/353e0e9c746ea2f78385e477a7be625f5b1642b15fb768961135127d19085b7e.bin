                                                _trackEvent","Factsheets","June",this.href]);">Download Factsheet</a>

                                            <a href="/downloads/portfolio-disclosure/Monthly-Portfolio_June-2014.xls"
                                                class="btn btn-outline-success" target="_blank" onclick="_gaq.push(["
                                                _trackEvent","Portfolio Disclossure","Excel",this.href]);">Detailed
