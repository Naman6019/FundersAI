<script type="text/javascript">
    
    var $affectedElements = $("p, table, tr, td, h1, h2, h3, h4, h5, h6, span, button, a"); // Can be extended, ex. $("div, p, span.someClass")
  
   
  $("#btn-increase").click(function(){
    changeFontSize(1);
  })
  
  $("#btn-decrease").click(function(){
    changeFontSize(-1);
  })
  
  function changeFontSize(direction){
      $affectedElements.each( function(){
          var $this = $(this);
          $this.css( "font-size" , parseInt($this.css("font-size"))+direction );
      });
  }
  
  $("#btn-orig").click(function(){
    $affectedElements.each( function(){
          var $this = $(this);
          $this.css( "font-size" , "16px" );
     });
  })
  
  </script>

<script>
  document.querySelectorAll('.social-icon').forEach(img => {
    img.addEventListener('mouseover', () => {
      if (img.dataset.hover) img.src = img.dataset.hover;
    });
    img.addEventListener('mouseout', () => {
      if (img.dataset.original) img.src = img.dataset.original;
    });
    img.addEventListener('error', () => {
      if (img.dataset.original) img.src = img.dataset.original;
    });
  });
</script>

